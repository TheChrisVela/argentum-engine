#!/usr/bin/env bash
#
# gradle-locked — run `./gradlew "$@"` under a machine-global exclusive lock.
#
# Why: each git worktree is a separate Gradle root, so N agents working in
# parallel each spawn their own Gradle daemon (-Xmx4g) + Kotlin daemon (-Xmx4g)
# + test JVM (2g), and each build defaults to max-workers = all CPU cores. On an
# 8-core/32GB box, three concurrent `./gradlew test` runs oversubscribe memory
# and CPU so badly that individual tests blow past the 300s HardTimeoutWatchdog
# hard cap (see TestHangGuard) and the whole run is halted — every agent "times
# out" at once.
#
# This wrapper serializes the heavy invocations: only one runs at a time across
# ALL worktrees on this machine; the rest queue (with a visible message) and run
# as soon as the lock frees. A single build already saturates 8 cores, so almost
# no real parallelism is lost — and "serialized but passing" beats "parallel but
# all failing".
#
# The lock lives at a fixed, worktree-independent path so every worktree's copy
# of this script contends for the same lock. shlock (shipped with macOS) is
# PID-aware: it auto-clears the lock if the holding process has died, so a
# crashed/killed run never wedges the queue.
#
# Tunables (env):
#   GRADLE_LOCK_TIMEOUT  seconds to wait before giving up (default 1800 = 30m)
#   GRADLE_LOCK_FILE     override the lock path (default ~/.cache/argentum/gradle.lock)

set -euo pipefail

LOCK_FILE="${GRADLE_LOCK_FILE:-$HOME/.cache/argentum/gradle.lock}"
TIMEOUT="${GRADLE_LOCK_TIMEOUT:-1800}"
POLL=5

mkdir -p "$(dirname "$LOCK_FILE")"

if ! command -v shlock >/dev/null 2>&1; then
    echo "gradle-locked: 'shlock' not found; running ./gradlew unlocked" >&2
    exec ./gradlew "$@"
fi

elapsed=0
until shlock -f "$LOCK_FILE" -p $$; do
    holder="$(cat "$LOCK_FILE" 2>/dev/null || echo '?')"
    if [ "$elapsed" -ge "$TIMEOUT" ]; then
        echo "gradle-locked: gave up after ${TIMEOUT}s waiting for Gradle lock (held by PID $holder)." >&2
        echo "gradle-locked: if that PID is dead, remove $LOCK_FILE and retry." >&2
        exit 1
    fi
    if [ "$elapsed" -eq 0 ]; then
        echo "gradle-locked: another Gradle run (PID $holder) is in progress — queuing (timeout ${TIMEOUT}s)..." >&2
    fi
    sleep "$POLL"
    elapsed=$((elapsed + POLL))
done

# We hold the lock; ensure it is released on any exit (success, failure, signal).
trap 'rm -f "$LOCK_FILE"' EXIT INT TERM

./gradlew "$@"
