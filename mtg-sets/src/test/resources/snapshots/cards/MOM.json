    "typeLine": "Creature — Phyrexian Shark",
    "oracleText": "Flying\nWhenever you cast a noncreature spell, incubate X, where X is that spell's mana value. (Create an Incubator token with X +1/+1 counters on it and \"{2}: Transform this token.\" It transforms into a 0/0 Phyrexian artifact creature.)",
    "creatureStats": {
        "power": 2,
        "toughness": 4
    },
    "keywords": [
        "FLYING"
    ],
    "script": {
        "triggeredAbilities": [
            {
                "id": "ability_1",
                "trigger": {
                    "type": "SpellCastEvent",
                    "spellFilter": {
                        "cardPredicates": [
                            "IsNoncreature"
                        ]
                    }
                },
                "binding": "ANY",
                "effect": {
                    "type": "Composite",
                    "effects": [
                        {
                            "type": "CreatePredefinedToken",
                            "tokenType": "Incubator"
                        },
                        {
                            "type": "AddDynamicCounters",
                            "counterType": "+1/+1",
                            "amount": {
                                "type": "EntityProperty",
                                "entity": "Triggering",
                                "numericProperty": "ManaValue"
                            },
                            "target": {
                                "type": "PipelineTarget",
                                "collectionName": "createdTokens"
                            }
                        }
                    ]
                }
            }
        ]
    },
    "metadata": {
        "collectorNumber": "51",
        "rarity": "RARE",
        "artist": "Donato Giancola",
        "imageUri": "https://cards.scryfall.io/normal/front/f/e/febaaeae-5c0d-45fa-8169-b27b4996f18e.jpg?1682203038",
        "rulings": [
            {
                "date": "2023-04-14",
                "text": "If the noncreature spell has {X} in its mana cost, use the value chosen for X when calculating that spell's mana value."
            }
        ]
    },
    "colorIdentityOverride": [
        "BLUE"
    ]
}

