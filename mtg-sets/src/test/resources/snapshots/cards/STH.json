                        }
                    ]
                }
            }
        ]
    },
    "metadata": {
        "collectorNumber": "51",
        "rarity": "UNCOMMON",
        "artist": "Kev Walker",
        "imageUri": "https://cards.scryfall.io/normal/front/9/1/91f05fc3-da6e-45d4-8566-f4e7bdce1fe5.jpg?1562596885",
